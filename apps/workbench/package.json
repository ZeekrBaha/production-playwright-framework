{
  "name": "forecast-workbench",
  "private": true,
  "version": "1.0.0",
  "description": "Forecast Workbench — frontend system under test for the e2e Playwright framework",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.0",
    "typescript": "^5.6.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
